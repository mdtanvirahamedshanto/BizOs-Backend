# ============================================
# BizOS Backend — Environment Variables
# ============================================

# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=BizOS
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://bizos:bizos_secret@localhost:5432/bizos_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Logging
LOG_LEVEL=debug

# API Documentation (disabled by default in production)
ENABLE_SWAGGER=true

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bizos.app

# SMS (placeholder)
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# Payment (placeholder)
PAYMENT_PROVIDER=stripe
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LINK_TTL_SEC=900
