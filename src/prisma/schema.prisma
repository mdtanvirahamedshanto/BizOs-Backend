  @@map("report_snapshots")
}

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  22. AUDIT LOGS — System Audit Trail (Immutable)                          ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

/// Immutable, append-only audit trail. Never deleted.
/// Consider partitioning by created_at at scale.
model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100) // sale.created, product.updated
  entity    String?  @db.VarChar(50) // Table name: sales, products
  entityId  String?  @map("entity_id") @db.Uuid
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // ── Relations ──
  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId, createdAt])
  @@index([shopId, action])
  @@index([shopId, entity, entityId], map: "idx_audit_logs_entity")
  @@index([createdAt])
  @@map("audit_logs")
}

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  23. CASHBOOK & FINANCE                                                   ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

enum CashbookEntryType {
  IN
  OUT
}

enum RecurringExpenseFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model CashbookEntry {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId              String            @map("shop_id") @db.Uuid
  type                CashbookEntryType
  amountCents         Int               @map("amount_cents")
  runningBalanceCents Int               @map("running_balance_cents")
  description         String
  referenceType       String?           @map("reference_type") @db.VarChar(50) // sale, purchase, expense, khata, manual
  referenceId         String?           @map("reference_id") @db.Uuid
  paymentId           String?           @map("payment_id") @db.Uuid
  recordedBy          String            @map("recorded_by") @db.Uuid
  entryDate           DateTime          @default(now()) @map("entry_date") @db.Timestamptz
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop     Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  recorder User @relation("CashbookEntryRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)

  @@index([shopId, entryDate])
  @@index([shopId, type])
  @@map("cashbook_entries")
}

model DailyClosing {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId               String   @map("shop_id") @db.Uuid
  closingDate          DateTime @map("closing_date") @db.Date
  openingBalanceCents  Int      @map("opening_balance_cents")
  cashInCents          Int      @map("cash_in_cents")
  cashOutCents         Int      @map("cash_out_cents")
  expectedBalanceCents Int      @map("expected_balance_cents")
  actualBalanceCents   Int      @map("actual_balance_cents")
  differenceCents      Int      @map("difference_cents")
  notes                String?
  closedBy             String   @map("closed_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop     Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  recorder User @relation("DailyClosingRecorder", fields: [closedBy], references: [id], onDelete: Restrict)

  @@unique([shopId, closingDate], map: "uq_daily_closings_shop_date")
  @@map("daily_closings")
}

model RecurringExpense {
  id            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId        String                    @map("shop_id") @db.Uuid
  categoryId    String?                   @map("category_id") @db.Uuid
  title         String                    @db.VarChar(300)
  description   String?
  amountCents   Int                       @map("amount_cents")
  paymentMethod PaymentMethod             @default(CASH) @map("payment_method")
  frequency     RecurringExpenseFrequency
  startDate     DateTime                  @map("start_date") @db.Timestamptz
  endDate       DateTime?                 @map("end_date") @db.Timestamptz
  nextDueDate   DateTime                  @map("next_due_date") @db.Timestamptz
  lastGenDate   DateTime?                 @map("last_gen_date") @db.Timestamptz
  isActive      Boolean                   @default(true) @map("is_active")
  recordedBy    String                    @map("recorded_by") @db.Uuid
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recorder User             @relation("RecurringExpenseRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)

  @@index([shopId, nextDueDate])
  @@index([shopId, isActive])
  @@map("recurring_expenses")
}

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  24. BANGLADESH FEATURES (MFS & FLEXILOAD)                                ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

enum MfsProvider {
  BKASH
  NAGAD
  ROCKET
  UPAY
}

enum MfsAccountType {
  AGENT
  MERCHANT
  PERSONAL
}

enum MfsTransactionType {
  CASH_IN
  CASH_OUT
  SEND_MONEY
  MERCHANT_PAY
  BILL_PAY
  ADJUSTMENT
}

enum MfsTxStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MobileOperator {
  GP
  ROBI
  AIRTEL
  BL
  TELETALK
}

enum FlexiloadStatus {
  PENDING
  COMPLETED
  FAILED
}

enum FlexiloadConnectionType {
  PREPAID
  POSTPAID
}

model MfsAccount {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId        String         @map("shop_id") @db.Uuid
  provider      MfsProvider
  accountNumber String         @map("account_number") @db.VarChar(20)
  accountType   MfsAccountType @default(AGENT) @map("account_type")
  balanceCents  Int            @default(0) @map("balance_cents")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop         Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  transactions MfsTransaction[]

  @@unique([shopId, provider, accountNumber], map: "uq_mfs_accounts_shop_provider_number")
  @@map("mfs_accounts")
}

model MfsTransaction {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId          String             @map("shop_id") @db.Uuid
  mfsAccountId    String             @map("mfs_account_id") @db.Uuid
  type            MfsTransactionType
  customerPhone   String             @map("customer_phone") @db.VarChar(20)
  amountCents     Int                @map("amount_cents")
  feeCents        Int                @default(0) @map("fee_cents")
  commissionCents Int                @default(0) @map("commission_cents")
  txid            String?            @db.VarChar(100)
  status          MfsTxStatus        @default(COMPLETED)
  notes           String?
  recordedBy      String             @map("recorded_by") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop       Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  mfsAccount MfsAccount @relation(fields: [mfsAccountId], references: [id], onDelete: Restrict)
  recorder   User       @relation("MfsTransactionRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)

  @@index([shopId, createdAt])
  @@index([shopId, mfsAccountId])
  @@map("mfs_transactions")
}

model FlexiloadAccount {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId        String                 @map("shop_id") @db.Uuid
  operator      MobileOperator
  accountNumber String                 @map("account_number") @db.VarChar(20)
  balanceCents  Int                    @default(0) @map("balance_cents")
  isActive      Boolean                @default(true) @map("is_active")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop         Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  transactions FlexiloadTransaction[]

  @@unique([shopId, operator, accountNumber], map: "uq_flexiload_accounts_shop_operator_number")
  @@map("flexiload_accounts")
}

model FlexiloadTransaction {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId          String                  @map("shop_id") @db.Uuid
  accountId       String                  @map("account_id") @db.Uuid
  recipientPhone  String                  @map("recipient_phone") @db.VarChar(20)
  amountCents     Int                     @map("amount_cents")
  commissionCents Int                     @default(0) @map("commission_cents")
  status          FlexiloadStatus         @default(COMPLETED)
  connectionType  FlexiloadConnectionType @default(PREPAID) @map("connection_type")
  recordedBy      String                  @map("recorded_by") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  // ── Relations ──
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  flexiloadAccount FlexiloadAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  recorder         User             @relation("FlexiloadTransactionRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)

  @@index([shopId, createdAt])
  @@index([shopId, accountId])
  @@map("flexiload_transactions")
}
