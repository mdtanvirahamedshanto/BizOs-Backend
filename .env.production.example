# BizOS Production Environment
# Copy to .env.production and fill in strong secrets before deploy.

NODE_ENV=production
PORT=3000
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# Database — use connection pooling (PgBouncer recommended at scale)
# connection_limit caps Prisma pool size per process (api + worker + bot)
DATABASE_URL=postgresql://bizos:CHANGE_ME@postgres:5432/bizos_prod?schema=public&connection_limit=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# JWT — minimum 32 characters in production (enforced at startup)
JWT_ACCESS_SECRET=CHANGE_ME_TO_A_RANDOM_32_PLUS_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_32_PLUS_CHAR_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
CORS_ORIGINS=https://app.yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
JSON_BODY_LIMIT=1mb
ENABLE_SWAGGER=false
LOG_LEVEL=warn

# S3-compatible storage (MinIO / AWS S3 / Cloudflare R2)
STORAGE_ENDPOINT=https://s3.yourdomain.com
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME
STORAGE_BUCKET=bizos-uploads
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# Email / SMS (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bizos.app

# Telegram bot (optional — run bot service separately)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LINK_TTL_SEC=900
